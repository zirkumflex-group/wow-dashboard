LETSENCRYPT_EMAIL=infra@example.com

APP_DOMAIN=app.example.com
CONVEX_API_DOMAIN=api.example.com
CONVEX_SITE_DOMAIN=site.example.com

INSTANCE_NAME=wow-dashboard
INSTANCE_SECRET=replace-with-a-long-random-secret

CONVEX_REV=latest
DASHBOARD_PORT=6791

APPLICATION_MAX_CONCURRENT_MUTATIONS=16
APPLICATION_MAX_CONCURRENT_NODE_ACTIONS=16
APPLICATION_MAX_CONCURRENT_QUERIES=16
APPLICATION_MAX_CONCURRENT_V8_ACTIONS=16
DISABLE_METRICS_ENDPOINT=true
DOCUMENT_RETENTION_DELAY=172800
RUST_LOG=info
