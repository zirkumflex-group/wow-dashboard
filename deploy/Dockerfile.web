# syntax=docker/dockerfile:1.7
FROM node:20-slim AS base

ENV PNPM_HOME=/pnpm
ENV PATH="${PNPM_HOME}:${PATH}"

RUN corepack enable && corepack prepare pnpm@10.11.0 --activate

WORKDIR /app

FROM base AS pruner

COPY . .

RUN --mount=type=cache,id=wowdash-pnpm-store,target=/pnpm/store,sharing=locked \
  pnpm dlx turbo@2.8.20 prune --docker web --out-dir /pruned

FROM base AS deps

COPY --from=pruner /pruned/json/ .

RUN --mount=type=cache,id=wowdash-pnpm-store,target=/pnpm/store,sharing=locked \
  pnpm install --frozen-lockfile

FROM deps AS build

ARG VITE_API_URL

COPY --from=pruner /pruned/full/ .

ENV VITE_API_URL="${VITE_API_URL}"

RUN pnpm -F web build

FROM node:20-slim AS runtime

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3001
ENV HOST=0.0.0.0

COPY --from=build --chown=node:node /app/apps/web/.output /app

USER node

EXPOSE 3001

CMD ["node", "server/index.mjs"]
