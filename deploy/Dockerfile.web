FROM node:20-slim AS base

ENV PNPM_HOME=/pnpm
ENV PATH="${PNPM_HOME}:${PATH}"

RUN corepack enable

WORKDIR /app

FROM base AS build

ARG VITE_API_URL

COPY . .

RUN pnpm install --frozen-lockfile
RUN pnpm add -Dw @rollup/rollup-linux-x64-gnu@4.59.0 @rollup/rollup-linux-arm64-gnu@4.59.0 \
  && pnpm rebuild esbuild

ENV VITE_API_URL="${VITE_API_URL}"

RUN pnpm -F web build

FROM node:20-slim AS runtime

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3001
ENV HOST=0.0.0.0

COPY --from=build --chown=node:node /app/apps/web/.output /app

USER node

EXPOSE 3001

CMD ["node", "server/index.mjs"]
