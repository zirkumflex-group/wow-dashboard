{
  "name": "wow-dashboard",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-stack.mjs",
    "dev:services": "turbo run dev --filter=@wow-dashboard/api --filter=@wow-dashboard/worker --filter=web --filter=app",
    "dev:stop": "docker compose -f deploy/docker-compose.dev.yml stop postgres redis",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev --filter=web",
    "lint": "turbo run lint",
    "format:check": "turbo run format:check",
    "test": "turbo run test",
    "check": "turbo run lint format:check check-types",
    "verify": "turbo run lint format:check check-types test build"
  },
  "dependencies": {
    "dotenv": "catalog:"
  },
  "devDependencies": {
    "@wow-dashboard/config": "workspace:*",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "turbo": "^2.10.5",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@10.34.5",
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.6",
      "@types/node": "24.13.3",
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.7",
      "esbuild": "0.28.1",
      "fast-uri": "3.1.4",
      "form-data": "4.0.6",
      "hono": "4.12.31",
      "ip-address": "10.2.0",
      "js-yaml": "4.2.0",
      "qs@>=6.11.1 <=6.15.1": "6.15.3",
      "tar": "7.5.20",
      "tmp": "0.2.7",
      "undici": "6.27.0"
    }
  }
}
