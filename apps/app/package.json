{
  "name": "app",
  "version": "1.8.13",
  "private": true,
  "description": "",
  "keywords": [],
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "electron-vite build",
    "check-types": "tsc --noEmit --project tsconfig.node.json && tsc --noEmit --project tsconfig.web.json",
    "start": "node scripts/run-electron-vite.mjs preview",
    "package": "electron-builder --win"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "@wow-dashboard/api-client": "workspace:*",
    "electron-updater": "^6.8.3",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^5.2.0",
    "@wow-dashboard/config": "workspace:*",
    "@wow-dashboard/env": "workspace:*",
    "@wow-dashboard/ui": "workspace:*",
    "dotenv": "catalog:",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "zod": "catalog:"
  },
  "build": {
    "appId": "com.wow-dashboard.app",
    "publish": {
      "provider": "github",
      "owner": "zirkumflex-group",
      "repo": "wow-dashboard"
    },
    "productName": "WoW Dashboard",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/*.{md,txt,map}",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,CHANGES,changelog}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.bin"
    ],
    "extraMetadata": {
      "main": "./out/main/index.js"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "electronLanguages": [
        "en-US"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "artifactName": "wow-dashboard.exe"
    }
  }
}
