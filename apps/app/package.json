{
  "name": "app",
  "version": "1.9.14",
  "private": true,
  "description": "Self-hosted World of Warcraft character dashboard",
  "keywords": [],
  "author": "Zirkumflex Group",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "electron-vite build",
    "check-types": "tsc --noEmit --project tsconfig.node.json && tsc --noEmit --project tsconfig.web.json",
    "lint": "oxlint .",
    "format:check": "oxfmt --check .",
    "test": "tsx --test src/main/*.test.ts",
    "start": "node scripts/run-electron-vite.mjs preview",
    "package": "pnpm run build && electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "unzipper": "^0.12.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^5.2.0",
    "@wow-dashboard/config": "workspace:*",
    "@wow-dashboard/mythic-plus": "workspace:*",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.7",
    "electron-vite": "^5.0.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "^7.3.6"
  },
  "build": {
    "appId": "com.wow-dashboard.app",
    "electronUpdaterCompatibility": ">=2.16",
    "publish": {
      "provider": "github",
      "owner": "zirkumflex-group",
      "repo": "wow-dashboard"
    },
    "productName": "WoW Dashboard",
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/node_modules/argparse/**",
      "!**/node_modules/bluebird/js/browser/**",
      "!**/node_modules/js-yaml/bin/**",
      "!**/node_modules/js-yaml/dist/**",
      "!**/node_modules/node-int64/test.js",
      "!**/node_modules/semver/bin/**",
      "!**/*.{md,txt,map}",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,CHANGES,changelog}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.bin"
    ],
    "extraMetadata": {
      "main": "./out/main/index.js"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "electronLanguages": [
        "en-US"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "installerLanguages": [
        "en_US"
      ],
      "artifactName": "wow-dashboard.exe"
    }
  }
}
