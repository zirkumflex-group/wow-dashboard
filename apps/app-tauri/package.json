{
  "name": "app-tauri",
  "version": "1.9.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "check-types": "tsc --noEmit --project tsconfig.json",
    "cargo:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "cargo:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "package": "tauri build --target x86_64-pc-windows-msvc"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.1",
    "@tauri-apps/api": "^2.11.0",
    "@wow-dashboard/api-client": "workspace:*",
    "@wow-dashboard/env": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "catalog:",
    "typescript": "^6.0.3",
    "vite": "^7.3.2"
  }
}
