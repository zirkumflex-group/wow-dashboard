{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WoW Dashboard",
  "version": "1.9.1",
  "identifier": "com.wow-dashboard.app",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WoW Dashboard",
        "width": 900,
        "height": 600,
        "visible": false,
        "backgroundColor": "#030712"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "zirkumflex-group",
    "category": "Utility",
    "copyright": "Copyright zirkumflex-group",
    "shortDescription": "WoW Dashboard desktop uploader",
    "longDescription": "WoW Dashboard desktop uploader and addon sync client.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma",
        "startMenuFolder": "WoW Dashboard"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["wow-dashboard"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/zirkumflex-group/wow-dashboard/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGRTA2RTBEM0Q1RDNERjYKUldUMlBWMDlEVzdnejVyRFYzM1RLS3Y2SklxOXA4NllGRTIrSkJTSVNvWnFFN1dBOUdaM1diUm0K"
    }
  }
}
